{
  "name": "prompt-assistant",
  "version": "1.0.0",
  "description": "AI-powered prompt optimization assistant with ChatGPT-like interface",
  "private": true,
  "scripts": {
    "dev": "npm run env:setup && concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run start:dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "cd backend && npm run start:prod",
    "start:frontend": "cd frontend && npm run start",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "cd backend && npm run test",
    "test:frontend": "cd frontend && npm run test",
    "lint": "npm run lint:backend && npm run lint:frontend",
    "lint:backend": "cd backend && npm run lint",
    "lint:frontend": "cd frontend && npm run lint",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:build": "docker-compose build",
    "db:migrate": "cd backend && npx prisma migrate dev",
    "db:reset": "cd backend && npx prisma migrate reset",
    "db:seed": "cd backend && npx prisma db seed",
    "db:studio": "cd backend && npx prisma studio",
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "clean": "npm run clean:backend && npm run clean:frontend",
    "clean:backend": "cd backend && rm -rf dist node_modules",
    "clean:frontend": "cd frontend && rm -rf .next node_modules",
    "env:setup": "bash scripts/setup-env.sh development",
    "env:validate": "bash scripts/validate-env.sh",
    "env:production": "bash scripts/setup-env.sh production",
    "deploy:check": "bash scripts/pre-deploy-check.sh",
    "deploy:health": "bash scripts/health-check.sh",
    "deploy:setup": "bash scripts/deploy-setup.sh",
    "secrets:generate": "echo 'JWT_SECRET='$(openssl rand -base64 32) && echo 'SESSION_SECRET='$(openssl rand -base64 32)",
    "domain:check": "curl -I https://prompt-assistant.dukang.online && curl -I https://prompt-assistant.dukang.online/api/health"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.45.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  },
  "workspaces": [
    "frontend",
    "backend",
    "shared"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/prompt-assistant.git"
  },
  "keywords": [
    "ai",
    "prompt-engineering",
    "chatgpt",
    "nextjs",
    "nestjs",
    "gemini",
    "postgresql"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "@google/genai": "^1.15.0",
    "@radix-ui/react-scroll-area": "^1.2.10"
  }
}
